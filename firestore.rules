rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, create, update, delete: if roomId.size() >= 4 && roomId.size() <= 12;

      match /{candidates}/{docId} {
        allow read, create: if roomId.size() >= 4 && roomId.size() <= 12;
        allow update, delete: if false;
      }
    }
  }
}
